# Al-Murabbi - line-ending pins.
# Defect 40, MEASURED in session 28: a fresh clone with core.autocrlf=true injects
# 77 CR into worship-golden.json (SHA8 A13C34BA -> F48CB7C7) and 55 CR into
# worship-display.json (64B8A2C9 -> 9A56CC5B), and gate 7 exits 1.

# Byte-compared or SHA-pinned by the guards. LF forever, on every machine.
worship-golden.json      text eol=lf
worship-display.json     text eol=lf
quran-golden.json        text eol=lf
referral-golden.json     text eol=lf
adhkar.json              text eol=lf
lib/data/adhkar.json     text eol=lf

# recon-audit requires bare-LF = 0 inside index.html. Pure CRLF, on every machine.
index.html               text eol=crlf

# Zero-newline by design (gate 5 depends on it). Git must never rewrap these.
quran-uthmani.json       -text
mushaf-layout.json       -text

# Binary. Never convert.
*.gz                     binary
quest-data/*.json -text

# Defect 40 extended: these nine guard scripts were brought under git tracking in
# bug 43. Pin them to LF so a fresh clone with core.autocrlf=true cannot inject CR
# into them (a CR shift would corrupt the byte counts the guards measure).
worship-guard.cjs         text eol=lf
quran-guard.cjs           text eol=lf
layout-guard.cjs          text eol=lf
babel-gate.cjs            text eol=lf
runtime-gate.cjs          text eol=lf
recon-audit.cjs           text eol=lf
build-worship-display.cjs text eol=lf
referral-guard.cjs        text eol=lf
classifier-guard.cjs      text eol=lf
